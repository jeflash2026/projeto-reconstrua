# ── Reconstrua — variáveis de ambiente de PRODUÇÃO (exemplo) ─────────────────
# Copie para .env na VPS e preencha. NUNCA versione .env com segredos reais.
# O Go-Live Checklist (apps/api/dist/production/main.js) BLOQUEIA a subida se
# qualquer item obrigatório estiver ausente — nada sobe sem estar completo.
# Todas as variáveis abaixo são lidas por packages/application/.../production-config.ts.

# ── Portas (a API abre PORT, PORT+1, PORT+2, PORT+3) ─────────────────────────
PORT=3001

# ── PostgreSQL 16 — Event Store (append-only) + Read Models ──────────────────
# OBRIGATÓRIO. Migrações forward-only em infrastructure/database/init/ rodam no
# primeiro boot do container Postgres (docker-entrypoint-initdb.d).
POSTGRES_PASSWORD=
DATABASE_URL=postgres://reconstrua:SENHA@postgres:5432/reconstrua

# ── URL pública (OBRIGATÓRIO: precisa ser https:// no checklist) ─────────────
PUBLIC_URL=https://seu-dominio.com.br

# ── Evolution API (WhatsApp) — OBRIGATÓRIO ───────────────────────────────────
EVOLUTION_BASE_URL=https://evolution.seu-dominio.com.br
EVOLUTION_INSTANCE=ahri
EVOLUTION_API_KEY=
WHATSAPP_NUMBER=5511999999999

# ── LLM (OBRIGATÓRIO 1 provedor; go-live bloqueia 'offline') ─────────────────
# LLM_PROVIDER ∈ openai | anthropic | gemini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Meta Ads (opcional — atribuição/Pixel na landing) ────────────────────────
META_ACCESS_TOKEN=
META_PIXEL_ID=

# ── Identificação legal na landing (OBRIGATÓRIO p/ publicação — OAB Prov. 205/2021) ─
# Sem estes, o rodapé da landing exibe OAB/CNPJ em branco. Preencher antes de divulgar.
OAB_IDENTIFICACAO=
CNPJ=

# ── Autenticação do Portal Admin (BL-2.1 / DF-12) — OBRIGATÓRIO p/ publicar ─────
# Segredo que o Portal Admin apresenta (Bearer) à API. Vazio ⇒ Admin responde 401
# (fail-closed). O portal roda com ADMIN_API_TOKEN igual a este valor.
ADMIN_ACCESS_SECRET=

# ── Autenticação do Portal Advogado (BL-3.1 / DF-12) — OBRIGATÓRIO p/ publicar ──
# Segredo que o Portal Advogado apresenta (Bearer) à API. Vazio ⇒ /advogado* = 401
# (fail-closed). O portal roda com ADVOGADO_API_TOKEN igual a este valor.
ADVOGADO_ACCESS_SECRET=

# ── Autenticidade do webhook Evolution (B5.1) — OBRIGATÓRIO p/ publicar ──────────
# Segredo exigido em POST /webhook/evolution (via header apikey/Authorization Bearer
# ou ?token=). Vazio ⇒ usa o EVOLUTION_API_KEY acima como segredo (fail-closed: sem
# nenhum dos dois, o webhook recusa toda chamada). Configure a Evolution para enviá-lo.
# As rotas /production/* sensíveis (config/monitor/go-live/shadow) usam o ADMIN_ACCESS_SECRET.
WEBHOOK_SECRET=

# ── Conexão WhatsApp pelo Portal Admin (administração de instâncias Evolution) ───
# Chave GLOBAL da Evolution (AUTHENTICATION_API_KEY) — SÓ backend; nunca vai ao browser
# nem a logs/respostas. Necessária p/ criar/descartar instância pelo Portal. Vazio ⇒
# o Portal só exibe status/QR/valida a instância existente (não cria/descarta).
EVOLUTION_GLOBAL_API_KEY=
# Segredo de perfil FOUNDER/Super Admin — exigido (header x-founder-secret) para
# operações DESTRUTIVAS (criar/descartar/substituir instância). Distinto do ADMIN.
FOUNDER_ACCESS_SECRET=
# Número OFICIAL da empresa (só dígitos) — o ownerJid do WhatsApp lido no QR deve bater.
OFFICIAL_WHATSAPP_NUMBER=554137989737

# ── Portal do Cliente (PC-R3) ────────────────────────────────────────────────
# Segredo de assinatura do LINK MÁGICO do cliente (HMAC; fail-closed se vazio —
# sem ele o nascimento do Portal não comunica e nenhum token é válido).
CLIENTE_PORTAL_SECRET=
# A POLÍTICA de estimativa da análise (D1 — fonte ÚNICA): mensagem da AHRI e
# relógio do Portal usam este mesmo valor. Mudou a política, muda aqui, e só aqui.
PROCESSING_ESTIMATE_DAYS=12

# ── Operação ─────────────────────────────────────────────────────────────────
# SHADOW_MODE=true → registra Shadow Reports de cada turno (recomendado no início).
SHADOW_MODE=true
# ALLOW_DEGRADED=true → SÓ para homologação; permite subir com itens vermelhos.
ALLOW_DEGRADED=false
NODE_ENV=production
