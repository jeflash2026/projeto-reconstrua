# ── Reconstrua — variáveis de ambiente (exemplo) ─────────────────────────────
# Copie para .env e ajuste. NUNCA versione .env com segredos reais.

# PostgreSQL 16 — Event Store (lado de escrita) e Read Models (lado de leitura)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reconstrua
POSTGRES_USER=reconstrua_app
POSTGRES_PASSWORD=change_me_in_local_only

# Conexão da aplicação de escrita (event store).
# A aplicação escreve eventos via role com acesso ao schema event_store.
DATABASE_URL=postgres://reconstrua_app:change_me_in_local_only@localhost:5432/reconstrua

# Conexão das interfaces (SOMENTE leitura de read models — Canon DF-08, item 12).
# Role sem qualquer acesso ao schema event_store.
READ_MODEL_DATABASE_URL=postgres://reconstrua_read:change_me_in_local_only@localhost:5432/reconstrua

# Observabilidade (telemetria técnica — separada da Auditoria Constitucional)
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
NODE_ENV=development
