# ── Portal Admin (BL-2.2) — variáveis do processo Next (next start) ──────────────
# Copie para .env.local (ou defina no ambiente do processo do portal). NUNCA versione
# segredos reais. Estas variáveis vivem SÓ no servidor do portal (SSR/Server Actions).

# URL da API do ADMIN (porta interna, ex. 3002) alcançável pelo SERVIDOR do portal
# via rede Docker. O browser nunca a usa (todo acesso à API é server-side).
NEXT_PUBLIC_API_URL=http://api:3002

# Segredo do Admin (BL-2.1): DEVE ser idêntico ao ADMIN_ACCESS_SECRET da API.
# Fica apenas no servidor do portal; nunca é exposto ao browser.
ADMIN_API_TOKEN=

# Segredo FOUNDER/Super Admin (= FOUNDER_ACCESS_SECRET da API) — usado SERVER-SIDE
# (header x-founder-secret) para operações destrutivas da Conexão WhatsApp (criar/
# descartar instância). Nunca vai ao browser.
FOUNDER_API_TOKEN=

# ── Atribuição de casos (BL-3.4) — o Admin chama a API EXISTENTE do Advogado ─────
# URL da API do ADVOGADO (porta interna, ex. 3003) alcançável pelo SERVIDOR do portal.
ADVOGADO_API_URL=http://api:3003
# Segredo do Advogado (= ADVOGADO_ACCESS_SECRET da API) p/ autenticar a atribuição.
ADVOGADO_API_TOKEN=
