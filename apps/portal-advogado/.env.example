# ── Portal Advogado (BL-3.1) — variáveis do processo Next (next start) ───────────
# Copie para .env.local (ou defina no ambiente do processo). Estas variáveis vivem
# SÓ no servidor do portal (SSR/Server Actions); nunca são expostas ao browser.

# URL da API do ADVOGADO (porta interna, ex. 3003) alcançável pelo SERVIDOR do portal
# via rede Docker. O browser nunca a usa.
NEXT_PUBLIC_API_URL=http://api:3003

# Segredo do Advogado (BL-3.1): DEVE ser idêntico ao ADVOGADO_ACCESS_SECRET da API.
ADVOGADO_API_TOKEN=
