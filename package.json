{
  "name": "reconstrua",
  "version": "0.0.0",
  "private": true,
  "description": "Projeto Reconstrua — Sistema Operacional Jurídico Cognitivo. Implementação derivada exclusivamente do Livro Mestre (constitution/).",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:conformance": "vitest run --project conformance --passWithNoTests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  },
  "pnpm": {
    "//": "canvas é dependência OPCIONAL do pdfjs (via unpdf), usada só para RENDER de imagem — a extração de TEXTO do HISCON não o usa. Nunca compilar (build nativo falha no Alpine e é desnecessário).",
    "neverBuiltDependencies": [
      "canvas"
    ]
  }
}
